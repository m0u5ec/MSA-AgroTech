@startuml
!include <C4/C4_Container>

LAYOUT_WITH_LEGEND()

title Платформа мониторинга скота «ФармПром X»

' Пользователи
Person(farmer, "Фермер [...]", "Управление кормушками, поилками, мониторинг животных, алерты  при авариях и ЧП")
Person(user, "Директор, аналитик, etc [...]", "Любой пользователь согласно ролевой модели")

' Граница ИТ-ландшафта ФармПром X
System_Boundary(farmprom_ecosystem, "Цифровая экосистема «ФармПром X»") {

    ' ГРАНИЦА ЛОКАЛЬНОГО АГЕНТА (На конкретной ферме)
    Container_Boundary(local_agent, "Локальный Агент (Контур конкретной фермы - Автономен)") {
        Container(video_server, "Видеосервер", "Go / C++", "Прием потоков со множества камер разных производителей")
        Container(local_ai, "Локальный ИИ-модуль", "Python", "Детекция драк, задавливаний, падежа, пересчет поголовья + анализ качества видео")
        Container(iot_gate, "IoT-Шлюз оборудования", "Node-RED / Python", "Управление освещением/кормушками/поилками, мониторинг фильтров воды")
        Container(local_db, "Локальная БД и Кэш", "SQLite / MQTT Jetstream", "Накопление данных при отсутствии интернета, локальные очереди")
        Container(local_notifier, "Модуль локальных алертов", "Go", "Отправка push/SMS дежурному сотруднику без интернета")
    }

    ' ГРАНИЦА ЦЕНТРАЛЬНОГО СЕРВЕРА
    Container_Boundary(central_server, "Ядро платформы (центральный сервер/облако)") {
        Container(sync_gate, "Шлюз синхронизации агентов", "Go / gRPC", "Прием данных от агентов с ферм (задержка до 10 мин)")
        Container(api_gateway, "API Gateway & Auth", "Управление доступом", "Разделение ролей, современные методы авторизации (OAuth2)")
        Container(metrics_mod, "Модуль метрик", "Python", "Расчет базовых и поддержка кастомных метрик")
        ContainerDb(central_db, "Центральная БД", "PostgreSQL / TimescaleDB", "Хранение профилей ферм, животных, истории и метрик")
    }

    ' Фронтенд
    Container(apps, "Приложения пользователя", "Web / Mobile", "Интерфейс фермера и руководства")
}

' Внешние системы
System_Ext(ext_ai, "ИИ-модель трекинга животных", "Внешний сервис глубокой аналитики видео")
System_Ext(hardware, "Камеры, Освещение, Кормушки, Поилки, Фильтры", "Физическое оборудование фермы")

' ВЗАИМОСВЯЗИ НА ФЕРМЕ (Локально)
Rel(hardware, video_server, "Передают видеопотоки (RTSP)", "Network")
Rel(hardware, iot_gate, "Передают телеметрию, принимают команды", "Modbus/MQTT")
Rel(video_server, local_ai, "Передает кадры для анализа")
Rel(local_ai, local_db, "Записывает события (ЧП, подсчет)")
Rel(iot_gate, local_db, "Записывает метрики датчиков и корма")
Rel(local_db, local_notifier, "Триггерит критические ЧП")
Rel(local_notifier, farmer, "Генерирует уведомление на месте при ЧП", "SMS/Локальная сеть")
Rel(farmer, iot_gate, "Прямое экстренное управление в локальной сети", "Web/SCADA")
Rel(local_ai, iot_gate, "Автоматическая коррекция освещения", )

' СИНХРОНИЗАЦИЯ АГЕНТ -> ЦЕНТР
Rel(local_db, sync_gate, "Репликация данных при наличии сети (батчи до 10 мин)", "gRPC")
Rel(sync_gate, central_db, "Сохраняет агрегированные данные по фермам")

' ВЗАИМОДЕЙСТВИЕ ПОЛЬЗОВАТЕЛЕЙ И ВНЕШНИХ СИСТЕМ С ЦЕНТРОМ
Rel(farmer, apps, "Использует для мониторинга и настроек")
Rel(user, apps, "Использует согласно ролевой модели")
Rel(apps, api_gateway, "Запросы к данным и управление", "REST API")
Rel(api_gateway, metrics_mod, "Запрос метрик")
Rel(metrics_mod, central_db, "Чтение/запись")
Rel(central_db, ext_ai, "Передает видеоданные для обучения и прогнозов", "gRPC")
Rel(local_ai, ext_ai, "Регулярное бновление модели при наличии связи", "ONNX")

@enduml
